{
  "name": "pi-hooks",
  "version": "0.1.0",
  "description": "Port of OpenCode-Hooks to the PI harness: YAML-driven hooks for PI sessions.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": [
    "pi-package"
  ],
  "files": [
    "src",
    "docs",
    "examples",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "bun src/pi/unsupported.test.ts && bun src/pi/ux-actions.test.ts && bun src/pi/config-paths.test.ts && bun src/pi/logger.test.ts && bun src/pi/logging.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KristjanPikhof/pi-hooks.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.68.1"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
